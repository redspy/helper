<%
const statusLabel = { pending: '대기', running: '실행중', sent: '전송완료', failed: '실패' }
const statusClass = { pending: 'status-pending', running: 'status-running', sent: 'status-sent', failed: 'status-failed' }
const recurrenceLabel = { once: '1회', daily: '매일', weekly: '매주', monthly: '매월', custom: '커스텀' }
%>
<tr>
  <td><strong><%= task.title %></strong></td>
  <td><%= task.scheduled_at %></td>
  <td><%= recurrenceLabel[task.recurrence_type] || task.recurrence_type %></td>
  <td><span class="status <%= statusClass[task.status] %>"><%= statusLabel[task.status] || task.status %></span></td>
  <td>
    <% if (task.last_run_at) { %>
      <%= task.last_run_at %>
      <% if (task.last_run_status === 'failed' && task.last_error) { %>
        <br><small class="error-text"><%= task.last_error %></small>
      <% } %>
    <% } else { %>
      -
    <% } %>
  </td>
  <td class="actions">
    <button class="btn btn-sm btn-edit" onclick="openEditModal(<%= JSON.stringify(task) %>)">수정</button>
    <form method="POST" action="/tasks/<%= task.id %>/delete" style="display:inline" onsubmit="return confirm('삭제하시겠습니까?')">
      <button type="submit" class="btn btn-sm btn-delete">삭제</button>
    </form>
    <form method="POST" action="/tasks/<%= task.id %>/run" style="display:inline" onsubmit="return confirm('지금 바로 실행하시겠습니까?')">
      <button type="submit" class="btn btn-sm btn-run" <%= task.status === 'running' ? 'disabled' : '' %>>실행</button>
    </form>
  </td>
</tr>
