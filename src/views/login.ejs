<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>로그인</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; color: #333; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .card { background: #fff; border-radius: 8px; padding: 40px 32px; box-shadow: 0 1px 4px rgba(0,0,0,.08); width: 100%; max-width: 360px; }
    h1 { font-size: 1.3rem; margin-bottom: 24px; text-align: center; }
    label { display: block; font-size: .8rem; font-weight: 600; color: #666; margin-bottom: 6px; }
    input[type="password"] { width: 100%; padding: 9px 12px; border: 1px solid #ddd; border-radius: 6px; font-size: .95rem; outline: none; }
    input[type="password"]:focus { border-color: #666; }
    button { width: 100%; margin-top: 16px; padding: 10px; background: #333; color: #fff; border: none; border-radius: 6px; font-size: .95rem; cursor: pointer; }
    button:hover { background: #555; }
    .error { margin-top: 12px; color: #c0392b; font-size: .85rem; text-align: center; }
  </style>
</head>
<body>
  <div class="card">
    <h1>🔒 접근 인증</h1>
    <form method="POST" action="/login">
      <label for="password">비밀번호</label>
      <input type="password" id="password" name="password" autofocus autocomplete="current-password">
      <button type="submit">확인</button>
      <% if (error) { %>
        <p class="error"><%= error %></p>
      <% } %>
    </form>
  </div>
</body>
</html>
